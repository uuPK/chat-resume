# Database Configuration
DATABASE_URL=sqlite:///./chat_resume.db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
AGENT_TRACE_LOG_ENABLED=true
AGENT_TRACE_CHUNK_LOG_ENABLED=false

# Frontend URL used by redirects and server-side export callbacks
FRONTEND_URL=http://localhost:3000

# Auth Cookie Configuration
# Use AUTH_COOKIE_SECURE=true in production HTTPS environments.
# Use AUTH_COOKIE_SAMESITE=none only when frontend and backend are cross-site.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# Google OAuth Login
# Create a Web application OAuth client in Google Cloud Console.
# Never commit real client secrets.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# PayPal Billing
# Use https://api-m.paypal.com in production.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# OpenRouter API
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct
OPENROUTER_VISION_FALLBACK_MODELS=google/gemini-2.5-flash
OPENROUTER_RESUME_PARSER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_CONNECT_TIMEOUT_SECONDS=15
OPENROUTER_READ_TIMEOUT_SECONDS=90
OPENROUTER_WRITE_TIMEOUT_SECONDS=30
OPENROUTER_FIRST_EVENT_TIMEOUT_SECONDS=45
OPENROUTER_FIRST_TOKEN_TIMEOUT_SECONDS=0
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BACKOFF_SECONDS=1.5

# Runtime logs
RELEASE_IDENTIFIER=

# MiniMax TTS API
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_GROUP_ID=

# Volcengine ASR API
VOLCENGINE_APP_KEY=
VOLCENGINE_ACCESS_TOKEN=
VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# Volcengine end-to-end realtime speech dialogue
# Set DIGITAL_HUMAN_PROVIDER=volcengine to enable this path.
DIGITAL_HUMAN_PROVIDER=volcengine
VOLCENGINE_DIALOGUE_APP_ID=
VOLCENGINE_DIALOGUE_ACCESS_KEY=
VOLCENGINE_DIALOGUE_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_DIALOGUE_SPEAKER_ID=
VOLCENGINE_DIALOGUE_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
